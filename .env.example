APP_NAME="Pattern RMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_base
DB_USERNAME=root
DB_PASSWORD=
DB_ENGINE=InnoDB

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_THROW=true
AWS_REPORT=true

OCR_ENABLED=true
OCR_PROVIDER=textract
OCR_TEXTRACT_MODE=detect_text
OCR_TEXT_FALLBACK=false
OCR_AWS_REGION="${AWS_DEFAULT_REGION}"
OCR_AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
OCR_AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"

SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD="ChangeMe123!"
CEO_NAME="Pattern CEO"
CEO_EMAIL=ceo@pattern.ae
CEO_PASSWORD="ChangeMe123!"
VAT_RATE=5
SEED_DEMO_DATA=false
WEB_UPDATER_ENABLED=true
GIT_BINARY=git
COMPOSER_BINARY=composer
COMPOSER_HOME=
NPM_BINARY=
TTLOCK_OAUTH_URL=https://api.ttlock.com
TTLOCK_API_URL=https://api.ttlock.com/v3
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="${APP_URL}"

VITE_APP_NAME="${APP_NAME}"
